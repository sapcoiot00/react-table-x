{
  "name": "dx-data-table",
  "version": "0.2.0",
  "description": "Headless, extensible, high-performance table engine for React.",
  "keywords": [
    "react",
    "table",
    "data-table",
    "datatable",
    "grid",
    "headless",
    "headless-table",
    "typescript",
    "sorting",
    "filtering",
    "pagination",
    "row-selection",
    "react-table",
    "table-component"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./features": {
      "types": "./dist/features/index.d.ts",
      "import": "./dist/features/index.js",
      "require": "./dist/features/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "example": "vite --host 127.0.0.1 examples/basic",
    "test": "vitest run",
    "benchmark": "vitest bench",
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts src/core/index.ts src/react/index.ts src/features/index.ts --format esm,cjs --dts --clean"
  },
  "peerDependencies": {
    "react": ">=18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
